# ══════════════════════════════════════════════════════════════════════
#  BuildSphere CV Service — Environment Variables
# ══════════════════════════════════════════════════════════════════════
#  Copy this file to .env and adjust values for your environment.
#  cp .env.example .env
# ══════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────
APP_NAME="BuildSphere Glass Panel Detector"
APP_VERSION="1.0.0"
DEBUG=true
HOST="0.0.0.0"
PORT=8000

# ── Model Configuration ──────────────────────────────────────────────
# For pre-trained demo (uses COCO "window" class as proxy):
MODEL_PATH="yolov8m.pt"
USE_PRETRAINED_COCO=true

# After training on custom glass panel dataset, switch to:
# MODEL_PATH="models/best.pt"
# USE_PRETRAINED_COCO=false

# ── Inference Thresholds ──────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.35
NMS_IOU_THRESHOLD=0.45
MAX_DETECTIONS=300
INFERENCE_IMAGE_SIZE=640

# ── Upload Limits ─────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=15
INFERENCE_TIMEOUT_SECONDS=30
